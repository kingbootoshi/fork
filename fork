#!/usr/bin/env bash
# fork - instant copy-on-write repo forks with forked agent chats.
#
# Run from inside Claude Code or Codex shell mode (!) to fork BOTH the repo
# and the current chat into a new tmux window, sitting in the clone.
# Run from a raw repo root to clone + branch + open a FRESH chat there.
#
#   fork <name>            clone + branch + chat in tmux:
#                            inside an agent -> forks the current chat
#                            raw terminal    -> fresh claude (FORK_AGENT=codex flips)
#   fork <name> --claude   claude in the fork (forks current claude chat, else fresh)
#   fork <name> --codex    codex in the fork (forks current codex chat, else fresh)
#   fork <name> --no-agent clone repo + branch + plain shell in tmux
#   fork <name> --to <ssh-host>  BEAM: rsync repo + chat to another machine,
#                            agent resumes in a remote tmux, local window
#                            auto-attaches over ssh (close the laptop freely)
#   fork <name> --bg       create the tmux window without switching focus to it
#   fork ls                list forks of the current repo
#   fork path <name>       print a fork's path
#   fork merge <name>      fetch fork/<name> branch back into the source repo
#   fork trash <name>      trash a fork (and kill its tmux window/session)
#
# Mechanism: APFS clonefile(2) snapshots the whole repo (git state, .env,
# node_modules, everything) in ~1s with zero disk cost. Claude chats fork via
# `claude --resume <id> --fork-session` (session file copied to the clone's
# project dir). Codex chats fork via native `codex fork <id>`.

set -euo pipefail

CLONEDIR="${FORK_CLONEDIR:-$HOME/.local/bin/clonedir}"
FORKS_BASENAME=".forks"

die() { printf 'fork: %s\n' "$*" >&2; exit 1; }
note() { printf '%s\n' "$*" >&2; }

usage() { sed -n "2,21p" "$0" | sed 's/^# \{0,1\}//'; }

repo_root() {
    git rev-parse --show-toplevel 2>/dev/null || die "not inside a git repo"
}

# Claude Code encodes project paths by replacing every non-alphanumeric char with '-'
encode_path() {
    local p="$1"
    printf '%s' "${p//[^A-Za-z0-9]/-}"
}

forks_dir_for() { # <root>
    local root="$1"
    printf '%s/%s/%s' "$(dirname "$root")" "$FORKS_BASENAME" "$(basename "$root")"
}

# ---------------------------------------------------------------------------
# agent selection: fork the current chat when inside one, start fresh otherwise
# ---------------------------------------------------------------------------

# Build the command that opens the chat inside the clone.
#   inside claude code (CLAUDE_CODE_SESSION_ID set) -> fork the current chat
#   inside codex (CODEX_THREAD_ID set)              -> fork the current chat
#   raw terminal                                    -> FRESH chat
# Default fresh agent is claude; set FORK_AGENT=codex to flip, or force with
# --claude / --codex. --no-agent opens a plain shell.
agent_command() { # <dst> <mode: auto|claude|codex|none>
    local dst="$1" mode="$2" sid src_file dst_enc

    case "$mode" in
        none) return 0 ;;
        auto)
            if   [ -n "${CLAUDE_CODE_SESSION_ID:-}" ]; then mode="claude"
            elif [ -n "${CODEX_THREAD_ID:-}" ];        then mode="codex"
            else mode="${FORK_AGENT:-claude}"
            fi ;;
    esac

    if [ "$mode" = "claude" ]; then
        sid="${CLAUDE_CODE_SESSION_ID:-}"
        src_file=""
        [ -n "$sid" ] && src_file=$(ls "$HOME/.claude/projects/"*/"$sid.jsonl" 2>/dev/null | head -1)
        if [ -n "$src_file" ]; then
            dst_enc=$(encode_path "$(cd "$dst" && pwd -P)")
            mkdir -p "$HOME/.claude/projects/$dst_enc"
            cp "$src_file" "$HOME/.claude/projects/$dst_enc/"
            printf 'claude --resume %s --fork-session' "$sid"
        else
            printf 'claude'
        fi
        return 0
    fi

    if [ "$mode" = "codex" ]; then
        if [ -n "${CODEX_THREAD_ID:-}" ]; then
            printf 'codex fork %s' "$CODEX_THREAD_ID"
        else
            printf 'codex'
        fi
        return 0
    fi
    die "unknown agent mode: $mode"
}

# ---------------------------------------------------------------------------
# tmux plumbing
# ---------------------------------------------------------------------------

open_in_tmux() { # <name> <repo> <dst> <cmd> <bg>
    local name="$1" repo="$2" dst="$3" cmd="$4" bg="$5"
    local setup="export COMPOSE_PROJECT_NAME=${repo}-${name}"
    local line="$setup"
    [ -n "$cmd" ] && line="$setup; $cmd"

    if [ -n "${TMUX:-}" ]; then
        local flags=(-P -F '#{window_id}' -n "$name" -c "$dst")
        [ "$bg" = "1" ] && flags=(-d "${flags[@]}")
        local wid
        wid=$(tmux new-window "${flags[@]}")
        tmux send-keys -t "$wid" "$line" Enter
        note "forked into tmux window '$name'"
    else
        local sess="fork-${repo}-${name}"
        sess="${sess//[.:]/-}"
        tmux new-session -d -s "$sess" -c "$dst" 2>/dev/null \
            || die "tmux session '$sess' already exists"
        tmux send-keys -t "$sess" "$line" Enter
        if [ "${TERM_PROGRAM:-}" = "Apple_Terminal" ] && [ -z "${SSH_TTY:-}" ] && [ "$bg" != "1" ]; then
            osascript -e "tell application \"Terminal\" to do script \"tmux attach -t $sess\"" >/dev/null 2>&1 \
                && note "forked into new Terminal window (tmux session '$sess')" \
                || note "attach with: tmux attach -t $sess"
        else
            note "attach with: tmux attach -t $sess"
        fi
    fi
}

# ---------------------------------------------------------------------------
# remote forks: beam the repo + chat to another machine over ssh
# ---------------------------------------------------------------------------

remote_zsh() { # <host> <command...>  - run through the remote login shell PATH
    ssh -o BatchMode=yes "$1" "zsh -lc $(printf '%q' "$2")"
}

# Build the agent command for a REMOTE fork and ship the session file there.
remote_agent_command() { # <host> <rdst_abs> <mode>
    local host="$1" rdst="$2" mode="$3" sid src_file renc rel

    case "$mode" in
        none) return 0 ;;
        auto)
            if   [ -n "${CLAUDE_CODE_SESSION_ID:-}" ]; then mode="claude"
            elif [ -n "${CODEX_THREAD_ID:-}" ];        then mode="codex"
            else mode="${FORK_AGENT:-claude}"
            fi ;;
    esac

    if [ "$mode" = "claude" ]; then
        sid="${CLAUDE_CODE_SESSION_ID:-}"
        src_file=""
        [ -n "$sid" ] && src_file=$(ls "$HOME/.claude/projects/"*/"$sid.jsonl" 2>/dev/null | head -1)
        if [ -n "$src_file" ]; then
            renc=$(encode_path "$rdst")
            remote_zsh "$host" "mkdir -p ~/.claude/projects/$renc"
            rsync -a "$src_file" "$host:.claude/projects/$renc/" >&2
            printf 'claude --resume %s --fork-session' "$sid"
        else
            printf 'claude'
        fi
        return 0
    fi

    if [ "$mode" = "codex" ]; then
        if [ -n "${CODEX_THREAD_ID:-}" ]; then
            src_file=$(find "$HOME/.codex/sessions" -name "*${CODEX_THREAD_ID}.jsonl" 2>/dev/null | head -1)
            if [ -n "$src_file" ]; then
                rel=${src_file#"$HOME/.codex/sessions/"}
                remote_zsh "$host" "mkdir -p ~/.codex/sessions/$(dirname "$rel")"
                rsync -a "$src_file" "$host:.codex/sessions/$rel" >&2
                printf 'codex fork %s --cd %s' "$CODEX_THREAD_ID" "$rdst"
            else
                printf 'codex'
            fi
        else
            printf 'codex'
        fi
        return 0
    fi
    die "unknown agent mode: $mode"
}

cmd_create_remote() { # <name> <host> <mode> <bg>
    local name="$1" host="$2" mode="$3" bg="$4"
    case "$name" in
        *[!A-Za-z0-9_-]*) die "remote fork names: letters, digits, - and _ only" ;;
    esac

    local root repo rbase rrepo rdst
    root=$(repo_root)
    repo=$(basename "$root")
    rbase="${FORK_REMOTE_BASE:-Dev/.forks}"
    rrepo="\$HOME/$rbase/$repo"

    remote_zsh "$host" "mkdir -p $rrepo && [ ! -e $rrepo/$name ]" \
        || die "fork '$name' already exists on $host (or ssh failed)"

    note "beaming $repo -> $host:~/$rbase/$repo/$name ..."
    local t0 t1
    t0=$(date +%s)
    rsync -az "$root/" "$host:$rbase/$repo/$name/"
    t1=$(date +%s)

    rdst=$(remote_zsh "$host" "cd $rrepo/$name && pwd -P")
    remote_zsh "$host" "git -C $rrepo/$name switch -c fork/$name" >/dev/null 2>&1 \
        || note "warning: branch fork/$name already exists on $host, staying on current branch"

    local cmd
    cmd=$(remote_agent_command "$host" "$rdst" "$mode")

    local sess="fork-${repo}-${name}"
    sess="${sess//[.:]/-}"
    local line="export COMPOSE_PROJECT_NAME=${repo}-${name}"
    [ -n "$cmd" ] && line="$line; $cmd"
    remote_zsh "$host" "tmux new-session -d -s $sess -c $rrepo/$name" \
        || die "tmux session '$sess' already exists on $host"
    remote_zsh "$host" "tmux send-keys -t $sess \"$line\" Enter"

    local attach="ssh -t $host \"zsh -lc 'tmux attach -t $sess'\""
    if [ "$bg" != "1" ]; then
        if [ -n "${TMUX:-}" ]; then
            tmux new-window -n "$name@$host" "$attach" \
                && note "attached in tmux window '$name@$host'"
        elif [ "${TERM_PROGRAM:-}" = "Apple_Terminal" ] && [ -z "${SSH_TTY:-}" ]; then
            osascript -e "tell application \"Terminal\" to do script \"$attach\"" >/dev/null 2>&1 \
                && note "attached in new Terminal window"
        fi
    fi
    note "attach anytime: $attach"
    note "beamed in $((t1 - t0))s -> $host, branch fork/$name, tmux '$sess'"
    case "$cmd" in
        *--fork-session|"codex fork"*) note "your current chat is forked and running on $host" ;;
        claude|codex)                  note "fresh $cmd chat running on $host" ;;
    esac
    printf '%s\n' "$host:$rdst"
}

# ---------------------------------------------------------------------------
# commands
# ---------------------------------------------------------------------------

cmd_create() {
    local name="" mode="auto" bg="0" host=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --claude) mode="claude" ;;
            --codex)  mode="codex" ;;
            --no-agent) mode="none" ;;
            --bg)     bg="1" ;;
            --to)     shift; host="${1:-}"; [ -n "$host" ] || die "--to needs an ssh host" ;;
            -*)       die "unknown flag: $1" ;;
            *)        [ -n "$name" ] && die "one fork name only"; name="$1" ;;
        esac
        shift
    done
    [ -n "$name" ] || { usage; exit 2; }

    if [ -n "$host" ]; then
        cmd_create_remote "$name" "$host" "$mode" "$bg"
        return 0
    fi
    case "$name" in
        */*|.*) die "fork name must be a simple name (no slashes, no leading dot)" ;;
    esac

    command -v tmux >/dev/null || die "tmux not installed"
    [ -x "$CLONEDIR" ] || die "clonedir helper missing - run install.sh"

    local root repo fdir dst
    root=$(repo_root)
    repo=$(basename "$root")
    fdir=$(forks_dir_for "$root")
    dst="$fdir/$name"
    [ -e "$dst" ] && die "fork '$name' already exists: $dst"
    mkdir -p "$fdir"

    local t0 t1
    t0=$(date +%s)
    "$CLONEDIR" "$root" "$dst"
    t1=$(date +%s)

    git -C "$dst" switch -c "fork/$name" >/dev/null 2>&1 \
        || note "warning: branch fork/$name already exists, staying on current branch"

    local cmd
    cmd=$(agent_command "$dst" "$mode")
    [[ "$cmd" == "codex fork "* ]] && cmd="$cmd --cd $dst"

    open_in_tmux "$name" "$repo" "$dst" "$cmd" "$bg"

    note "cloned in $((t1 - t0))s -> branch fork/$name"
    case "$cmd" in
        *--fork-session|"codex fork"*) note "forked your current chat into it" ;;
        claude|codex)                  note "opened a fresh $cmd chat in it" ;;
        "")                            note "opened a plain shell" ;;
    esac
    printf '%s\n' "$dst"
}

cmd_ls() {
    local root fdir d branch
    root=$(repo_root)
    fdir=$(forks_dir_for "$root")
    [ -d "$fdir" ] || { note "no forks for $(basename "$root")"; return 0; }
    for d in "$fdir"/*/; do
        [ -d "$d" ] || continue
        branch=$(git -C "$d" branch --show-current 2>/dev/null || echo "?")
        printf '%-24s %-28s %s\n' "$(basename "$d")" "$branch" "${d%/}"
    done
}

cmd_path() {
    local root dst
    root=$(repo_root)
    dst="$(forks_dir_for "$root")/$1"
    [ -d "$dst" ] || die "no fork named '$1'"
    printf '%s\n' "$dst"
}

cmd_merge() {
    local root dst branch
    root=$(repo_root)
    dst="$(forks_dir_for "$root")/$1"
    [ -d "$dst" ] || die "no fork named '$1'"
    branch=$(git -C "$dst" branch --show-current)
    [ -n "$branch" ] || die "fork '$1' is on detached HEAD"
    git -C "$root" fetch "$dst" "$branch:$branch"
    note "fetched '$branch' into $(basename "$root")"
    note "next: git merge $branch   (or open a PR from it)"
}

cmd_rm() {
    local root repo dst sess
    root=$(repo_root)
    repo=$(basename "$root")
    dst="$(forks_dir_for "$root")/$1"
    [ -d "$dst" ] || die "no fork named '$1'"
    sess="fork-${repo}-$1"; sess="${sess//[.:]/-}"
    tmux kill-session -t "$sess" 2>/dev/null || true
    if [ -n "${TMUX:-}" ]; then tmux kill-window -t "$1" 2>/dev/null || true; fi
    if command -v trash >/dev/null; then trash "$dst"; else rm -rf "$dst"; fi
    note "removed fork '$1'"
}

case "${1:-}" in
    ""|-h|--help|help) usage ;;
    ls|list)           cmd_ls ;;
    path|cd)           shift; [ $# -ge 1 ] || die "usage: fork path <name>"; cmd_path "$1" ;;
    merge)             shift; [ $# -ge 1 ] || die "usage: fork merge <name>"; cmd_merge "$1" ;;
    rm|remove|trash)   shift; [ $# -ge 1 ] || die "usage: fork rm <name>"; cmd_rm "$1" ;;
    *)                 cmd_create "$@" ;;
esac
